<%- include('partials/head', { pageTitle, bodyClass: 'home-page' }) %>
<%- include('partials/nav', { activePage }) %>

<main id="conteudo">
  <section class="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <canvas id="sparks" aria-hidden="true"></canvas>
    <div class="hero-frame" data-motion="fade-up">
      <p class="band-eyebrow">Heavy Metal • Brasil</p>
      <h1 class="band-name">
        <img src="/images/logo-tremendvz.png" alt="TREMENDVZ">
      </h1>
      <p class="band-subtitle">Não sou conduzido, conduzo</p>
      <div class="hero-divider" aria-hidden="true"></div>
      <div class="hero-cta">
        <a class="btn-primary" href="/album">Último Lançamento</a>
        <a class="btn-secondary" href="/discografia">Explorar Discografia</a>
      </div>
    </div>
    <div class="hero-status" data-motion="fade-up" style="--delay: 120ms">
      <span>Glória e Sangue</span>
      <span>2025</span>
      <span>5 faixas</span>
    </div>
  </section>

  <section class="section home-preview" aria-labelledby="home-sections">
    <div class="section-shell">
      <div class="section-heading" data-motion="fade-up">
        <p class="section-label">Arquivo Oficial</p>
        <h2 id="home-sections" class="section-title">Escolha o portal</h2>
      </div>

      <div class="preview-grid">
        <a class="feature-card feature-card-wide" href="/album" data-motion="fade-up" style="--delay: 40ms">
          <img src="<%= album.cover %>" alt="Capa do álbum <%= album.title %>">
          <span class="feature-kicker">Último Lançamento</span>
          <strong><%= album.title %></strong>
          <span><%= album.type %> · <%= album.year %></span>
        </a>

        <a class="feature-card" href="/discografia" data-motion="fade-up" style="--delay: 90ms">
          <span class="feature-kicker">Catálogo</span>
          <strong>Discografia em blocos</strong>
          <span>Álbuns abrem suas faixas; singles ficam diretos.</span>
        </a>

        <a class="feature-card" href="/banda" data-motion="fade-up" style="--delay: 140ms">
          <span class="feature-kicker">Manifesto</span>
          <strong>Forja brasileira de heavy metal</strong>
          <span>Guerra, honra e intensidade humana.</span>
        </a>

        <a class="feature-card" href="/galeria" data-motion="fade-up" style="--delay: 190ms">
          <span class="feature-kicker">Visual</span>
          <strong>Galeria oficial</strong>
          <span>Registros publicados somente pela administração.</span>
        </a>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
